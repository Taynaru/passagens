# ===== ROTA =====
ORIGIN=FOR                 # Fortaleza
DESTINATION=CNF            # Belo Horizonte / Confins (use BHZ p/ todos aeroportos de BH)
ADULTS=1
CURRENCY=BRL

# ===== JANELA DE BUSCA (sem data fixa) =====
START_DAYS=21             # começa a procurar a partir de X dias de hoje
END_DAYS=120             # até X dias de hoje
STEP_DAYS=7             # amostra datas de ida de quantos em quantos dias
TRIP_NIGHTS=4,7,10     # durações de viagem (noites) testadas em cada ida
MAX_PAIRS=40           # teto de combinações por ciclo (protege a cota da API)

# ===== PROVEDORES =====
ENABLE_CASH=true
ENABLE_MILES=true
USE_SAMPLE_DATA=false      # true = ignora as APIs e usa dados simulados (teste)
CASH_PROVIDER=travelpayouts # travelpayouts (recomendado) | amadeus

# ===== TRAVELPAYOUTS (preços em dinheiro — fonte gratuita recomendada) =====
# Token grátis em travelpayouts.com (Ferramentas -> API). Depois:
#   python main.py travelpayouts-setup --token SEU_TOKEN
TRAVELPAYOUTS_TOKEN=

# ===== AMADEUS (alternativa — portal self-service será desligado em jul/2026) =====
AMADEUS_ENV=test        # test (cota grande, dados de teste) | production (dados reais)
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# ===== SMILES (milhas) — instável; veja providers/smiles.py =====
SMILES_BASE_URL=https://api-air-flightsearch-prd.smiles.com.br/v1/airlines/search
SMILES_API_KEY=

# ===== LIMIARES DE ALERTA =====
CASH_THRESHOLD=700      # avisa se a ida+volta em dinheiro ficar <= isto (R$)
MILES_THRESHOLD=20000   # avisa se a ida+volta em milhas ficar <= isto
ALERT_ON_NEW_LOW=true   # avisa também quando bater nova mínima do período
NEW_LOW_DAYS=30
ALERT_COOLDOWN_HOURS=12 # não repete alerta das mesmas datas dentro disso

# ===== TELEGRAM (alerta instantâneo no celular) =====
# Crie um bot com @BotFather, copie o token e rode:
#   python main.py telegram-setup --token SEU_TOKEN
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== E-MAIL (SMTP) — opcional =====
# Gmail: use uma "Senha de app" (myaccount.google.com -> Segurança -> Senhas de app)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app
EMAIL_FROM=seu_email@gmail.com
EMAIL_TO=seu_email@gmail.com
